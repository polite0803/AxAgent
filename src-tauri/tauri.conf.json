{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AxAgent",
  "version": "1.0.0",
  "identifier": "top.axagent.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:skip-typecheck",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AxAgent",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": true,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' blob: 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; connect-src 'self' https: http://localhost:* http://127.1.0.0:* ipc: http://ipc.localhost:*; font-src 'self' data:; worker-src 'self' blob: ipc: http://ipc.localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    },
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "",
      "endpoints": []
    }
  }
}
