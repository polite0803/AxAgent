{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AxAgent",
  "version": "1.0.0",
  "identifier": "top.axagent.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:skip-typecheck",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AxAgent",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": true,
        "focus": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "languages": ["en_US", "zh_CN"]
      }
    },
    "macos": {
      "languages": ["en", "zh-CN"]
    },
    "linux": {
      "languages": ["en", "zh-CN"]
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg5NkUyODQxNTVEQTBFMQpSV1Rob0YwVmhPS1dDQlQvRkQ5MTdXTzNOMUlWdjJRL3JLSDR2RzBFakxaOTlpMjVBeXFjZ0NnbAo=",
      "endpoints": [
        "https://github.com/polite0803/AxAgent/releases/latest/download/latest.json"
      ]
    }
  }
}