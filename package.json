    "antd-style": "^4.1.0",
    "clsx": "^2.1.1",
    "emoji-picker-element": "^1.29.1",
    "html2canvas": "^1.4.1",
    "i18next": "^26.0.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "katex": "^0.16.45",
    "lucide-react": "1.8.0",
