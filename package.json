    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "^10.5.0",
    "dprint": "^0.45.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.2",
